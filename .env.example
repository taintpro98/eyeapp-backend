# Secrets only - load via environment or .env
# Public config lives in configs/config.yml
# DATABASE_URL overrides DB_* when set (e.g. for Docker)

# PostgreSQL (use DB_* or DATABASE_URL). For Docker: DB_HOST=database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=eyeapp_dev
DB_SSL_MODE=disable

# JWT secret key - CHANGE THIS IN PRODUCTION
JWT_SECRET=change_me_in_production

# App config (used when running via Docker)
APP_ENV=development
LOG_FORMAT=json
APP_VERIFY_URL_BASE=http://localhost:5173/verify-email

# Email verification (Resend)
RESEND_API_KEY=
EMAIL_FROM=ALumiEye <onboarding@resend.dev>
