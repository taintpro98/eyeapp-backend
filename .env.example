# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
APP_ENV=development          # development | production
LOG_FORMAT=json              # json | pretty (empty = pretty in dev)

# ──────────────────────────────────────────────
# eyeapp PostgreSQL (main DB)
# Use DATABASE_URL to override DB_* variables
# ──────────────────────────────────────────────
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=eyeapp_dev
DB_SSL_MODE=disable

# Connection pool (optional — defaults shown)
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_MINUTES=5

# ──────────────────────────────────────────────
# eyebroker PostgreSQL (read-only, orders)
# Use EYEBROKER_DATABASE_URL to override EYEBROKER_DB_* variables
# ──────────────────────────────────────────────
EYEBROKER_DATABASE_URL=
EYEBROKER_DB_HOST=localhost
EYEBROKER_DB_PORT=5433
EYEBROKER_DB_USER=root
EYEBROKER_DB_PASSWORD=123456
EYEBROKER_DB_NAME=eyebroker
EYEBROKER_DB_SSL_MODE=disable

# ──────────────────────────────────────────────
# Auth
# ──────────────────────────────────────────────
JWT_SECRET=change_me_in_production

# ──────────────────────────────────────────────
# Email (Resend)
# ──────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=ALumiEye <onboarding@resend.dev>
APP_VERIFY_URL_BASE=http://localhost:5173/verify-email
