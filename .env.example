# Application environment (development, staging, production)
APP_ENV=development

# Server port
PORT=8080

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/alumieye?sslmode=disable

# JWT secret key - CHANGE THIS IN PRODUCTION
JWT_SECRET=change_me_in_production

# Access token time-to-live in minutes
ACCESS_TOKEN_TTL_MINUTES=15

# Refresh token time-to-live in hours (default: 30 days)
REFRESH_TOKEN_TTL_HOURS=720

# Logging configuration
LOG_LEVEL=info          # debug, info, warn, error
LOG_FORMAT=json        # json (production), console (development). Empty = auto from APP_ENV
SERVICE_NAME=alumieye-api
